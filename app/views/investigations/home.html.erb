<% content_for :title, t(".title") %>

<main class="landing-shell">
  <section class="hero-card">
    <p class="eyebrow"><%= t(".eyebrow") %></p>
    <h1><%= t(".heading") %></h1>
    <p class="hero-copy"><%= t(".hero_copy") %></p>

    <%= form_with url: root_path, method: :get, class: "investigation-form", local: true do |form| %>
      <%= form.url_field :url,
          value: @submitted_url,
          placeholder: t(".placeholder"),
          required: true,
          class: "url-input" %>
      <%= form.submit t(".submit"), class: "submit-button" %>
    <% end %>

    <% if @error_message.present? %>
      <p class="form-error"><%= @error_message %></p>
    <% end %>
  </section>
</main>
