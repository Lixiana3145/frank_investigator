<% content_for :title, t(".title") %>

<main class="w-full max-w-[1120px] mx-auto px-4 py-8">
  <section class="max-w-3xl mx-auto mt-[8vh] p-8 md:p-10 border border-line bg-card backdrop-blur-sm rounded-3xl shadow-lg">
    <p class="mb-3 text-muted text-xs tracking-[0.14em] uppercase"><%= t(".eyebrow") %></p>
    <h1 class="mb-3 font-serif text-[clamp(2.2rem,5vw,4rem)] leading-[0.95]"><%= t(".heading") %></h1>
    <p class="text-muted"><%= t(".hero_copy") %></p>

    <%= form_with url: root_path, method: :get, class: "flex flex-wrap gap-3 mt-6", local: true do |form| %>
      <%= form.url_field :url,
          value: @submitted_url,
          placeholder: t(".placeholder"),
          required: true,
          class: "flex-1 basis-[420px] min-h-14 px-4 py-3.5 border border-line rounded-full bg-white/85 text-ink font-serif" %>
      <%= form.submit t(".submit"), class: "min-h-14 px-6 py-3.5 border-0 rounded-full bg-ink text-white cursor-pointer font-serif" %>
    <% end %>

    <% if @error_message.present? %>
      <p class="mt-4 text-verdict-red"><%= @error_message %></p>
    <% end %>
  </section>
</main>
