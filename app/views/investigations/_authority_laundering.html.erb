<% data = investigation.authority_laundering %>
<% return unless investigation.completed? && data.present? %>
<% chains = Array(data["chains"]) %>
<% return if chains.empty? && data["laundering_score"].to_f == 0 %>

<%
  score = data["laundering_score"].to_f
  callout_color = score >= 0.5 ? "border-l-verdict-red bg-verdict-red/4" : score >= 0.2 ? "border-l-verdict-amber bg-verdict-amber/4" : "border-l-verdict-green bg-verdict-green/4"
%>

<section class="border border-line rounded-3xl p-5 mb-4 border-l-4 <%= callout_color %>">
  <h3 class="font-bold mb-2"><%= t("investigations.authority_laundering.heading") %></h3>
  <p class="text-muted mb-3"><%= data["summary"] %></p>

  <dl class="grid grid-cols-[repeat(auto-fit,minmax(120px,1fr))] gap-3 mb-3">
    <div>
      <dt class="text-muted text-xs"><%= t("investigations.authority_laundering.laundering_score") %></dt>
      <dd class="mt-0.5 font-bold flex items-center gap-1.5">
        <span class="inline-block w-12 h-1.5 bg-black/8 rounded-full overflow-hidden">
          <span class="block h-full rounded-full score-fill <%= score_color_class(1.0 - score) %>" style="width: <%= score_bar_width(score) %>%"></span>
        </span>
        <span><%= score_percent(score * 100) %></span>
      </dd>
    </div>
  </dl>

  <% if chains.any? %>
    <details class="mt-2 p-3 bg-black/2 rounded-xl border border-line/40" open>
      <summary class="cursor-pointer text-sm text-muted hover:text-ink"><%= t("investigations.authority_laundering.detected_chains") %> (<%= chains.size %>)</summary>
      <ul class="mt-2 grid gap-3 list-none p-0 m-0">
        <% chains.each do |chain| %>
          <li class="py-2 border-b border-line/30 last:border-b-0">
            <div class="flex gap-2 mb-1">
              <span class="<%= fallacy_severity_badge(chain["severity"]) %>"><%= chain["severity"]&.capitalize %></span>
              <span class="text-muted text-xs"><%= chain["originating_authority"] %> &rarr; <%= chain["final_authority"] %></span>
            </div>
            <div class="flex flex-wrap items-center gap-1 text-xs text-muted my-1">
              <% Array(chain["steps"]).each_with_index do |step, i| %>
                <span class="px-1.5 py-0.5 bg-black/5 rounded"><%= step["host"] %> (<%= step["authority_tier"] %>)</span>
                <% if i < Array(chain["steps"]).size - 1 %><span>&rarr;</span><% end %>
              <% end %>
            </div>
            <p class="text-sm"><%= chain["explanation"] %></p>
          </li>
        <% end %>
      </ul>
    </details>
  <% end %>
</section>
