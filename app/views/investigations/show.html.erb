<% content_for :title, t(".title") %>

<%= turbo_stream_from @investigation %>

<main class="w-full max-w-[1120px] mx-auto px-4 py-8 pb-16">
  <header class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-6">
    <div>
      <p class="mb-3 text-muted text-xs tracking-[0.14em] uppercase"><%= t(".eyebrow") %></p>
      <h1 class="font-serif text-[clamp(2.2rem,5vw,4rem)] leading-[0.95]"><%= t(".heading") %></h1>
      <p class="text-muted"><%= @investigation.normalized_url %></p>
    </div>

    <%= form_with url: root_path, method: :get, class: "flex flex-wrap gap-3", local: true do |form| %>
      <%= form.url_field :url, value: @investigation.normalized_url, class: "flex-1 basis-[420px] min-h-12 px-4 py-3 border border-line rounded-full bg-white/85 text-ink font-serif", required: true %>
      <%= form.submit t(".rerun"), class: "min-h-12 px-5 py-3 border-0 rounded-full bg-ink text-white cursor-pointer font-serif" %>
    <% end %>
  </header>

  <% if @failure_info.present? %>
    <section class="border border-line bg-verdict-red/4 rounded-3xl p-5 mb-4 border-l-4 border-l-verdict-red">
      <h2 class="text-verdict-red text-lg font-bold"><%= t(".investigation_failed") %></h2>
      <p><%= @failure_info[:user_message] %></p>
      <details class="my-2">
        <summary class="cursor-pointer text-muted text-sm hover:text-ink"><%= t(".technical_details") %></summary>
        <p class="text-muted">
          <%= t(".step_label") %> <%= @failure_info[:step_name] %><br>
          <% if @failure_info[:error_class].present? %>
            <%= t(".error_label") %> <%= @failure_info[:error_class] %><br>
          <% end %>
          <% if @failure_info[:error_message].present? %>
            <%= t(".message_label") %> <%= @failure_info[:error_message].truncate(300) %>
          <% end %>
        </p>
      </details>
      <p>
        <%= link_to t(".try_again"), root_path(url: @investigation.normalized_url), class: "inline-block min-h-12 px-5 py-3 rounded-full bg-ink text-white no-underline font-serif" %>
      </p>
    </section>
  <% end %>

  <%= render "summary_cards", investigation: @investigation %>

  <% unless @investigation.completed? || @investigation.failed? %>
    <section class="flex items-center gap-3 mb-4 px-5 py-3 border border-verdict-amber/25 rounded-xl bg-verdict-amber/6 text-sm" id="progress_banner">
      <span class="inline-block w-2.5 h-2.5 rounded-full bg-verdict-amber shrink-0 animate-pulse-dot"></span>
      <span>
        <%= t("investigations.progress.analyzing") %>
        <% if (step = active_step_name(@investigation)) %>
          &mdash; <%= step %>
        <% end %>
      </span>
      <span class="text-muted">
        <%= @investigation.pipeline_steps.where(status: "completed").count %>/<%= @investigation.pipeline_steps.count %>
        <%= t("investigations.progress.steps_done") %>
      </span>
    </section>
  <% end %>

  <% if @investigation.headline_bait_score > 0 %>
    <%= render "headline_bait", investigation: @investigation %>
  <% end %>

  <%= render "rhetorical_analysis", investigation: @investigation %>

  <section class="grid grid-cols-1 lg:grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-4">
    <%= render "root_article_panel", root_article: @root_article %>

    <article class="border border-line bg-card backdrop-blur-sm rounded-3xl p-5 shadow-lg" id="checkable_claims">
      <h2 class="text-lg font-bold mb-4"><%= t(".what_we_checked") %></h2>
      <% if @checkable_claims.any? %>
        <% @checkable_claims.each do |assessment| %>
          <%= render "claim_assessment", assessment: %>
        <% end %>
      <% elsif @investigation.completed? && @investigation.not_checkable? %>
        <p class="text-muted"><%= t(".no_checkable_claims") %></p>
      <% else %>
        <p class="text-muted"><%= t(".claims_pending") %></p>
      <% end %>
    </article>

    <article class="border border-line bg-card backdrop-blur-sm rounded-3xl p-5 shadow-lg" id="uncheckable_claims">
      <h2 class="text-lg font-bold mb-4"><%= t(".what_we_could_not_check") %></h2>
      <% if @uncheckable_claims.any? %>
        <% @uncheckable_claims.each do |assessment| %>
          <section class="pt-4 border-t border-line/60 first:pt-0 first:border-t-0">
            <p class="text-base leading-relaxed"><%= assessment.claim.canonical_text %></p>
            <p class="flex flex-wrap gap-3 text-muted">
              <span class="<%= badge_class_for(assessment.checkability_status) %>"><%= te(:checkability_status, assessment.checkability_status) %></span>
              <% if assessment.claim.claim_kind != "statement" %>
                <span class="<%= badge_class_for("not_checkable") %>"><%= te(:claim_kind, assessment.claim.claim_kind) %></span>
              <% end %>
            </p>
            <p class="text-muted"><%= assessment.reason_summary.presence || t(".default_uncheckable_reason") %></p>
          </section>
        <% end %>
      <% else %>
        <p class="text-muted"><%= t(".uncheckable_pending") %></p>
      <% end %>
    </article>

    <%= render "evidence_timeline", investigation: @investigation %>

    <%= render "source_graph", links: @links, investigation: @investigation %>

    <%= render "pipeline_panel", steps: @pipeline_steps %>
  </section>
</main>
