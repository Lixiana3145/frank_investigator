<article class="border border-line bg-card backdrop-blur-sm rounded-3xl p-5 shadow-lg">
  <h2 class="text-lg font-bold mb-4"><%= t("investigations.pipeline_panel.heading") %></h2>
  <% if steps.any? %>
    <ul class="grid gap-3 m-0 p-0 list-none">
      <% steps.each do |step| %>
        <%= render "pipeline_step", step: step %>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted"><%= t("investigations.pipeline_panel.empty") %></p>
  <% end %>
</article>
