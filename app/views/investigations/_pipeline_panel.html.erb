<article class="panel">
  <h2>Pipeline steps</h2>
  <% if steps.any? %>
    <ul class="steps-list">
      <% steps.each do |step| %>
        <%= render "pipeline_step", step: step %>
      <% end %>
    </ul>
  <% else %>
    <p class="empty-state">Jobs have not started yet.</p>
  <% end %>
</article>
