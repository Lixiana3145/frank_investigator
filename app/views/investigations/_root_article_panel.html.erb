<article class="panel">
  <h2><%= t("investigations.root_article_panel.heading") %></h2>
  <% if root_article.present? %>
    <dl class="fact-list">
      <div>
        <dt><%= t("investigations.root_article_panel.title") %></dt>
        <dd><%= root_article.title.presence || t("investigations.root_article_panel.pending_fetch") %></dd>
      </div>
      <div>
        <dt><%= t("investigations.root_article_panel.fetch_status") %></dt>
        <dd><span class="<%= badge_class_for(root_article.fetch_status) %>"><%= root_article.fetch_status.humanize %></span></dd>
      </div>
      <div>
        <dt><%= t("investigations.root_article_panel.source_kind") %></dt>
        <dd><%= root_article.source_kind.humanize %></dd>
      </div>
      <div>
        <dt><%= t("investigations.root_article_panel.authority_tier") %></dt>
        <dd>
          <span class="has-popover">
            <%= root_article.authority_tier.humanize %> (<%= score_percent(root_article.authority_score * 100) %>)
            <span class="popover-content"><%= authority_tier_description(root_article.authority_tier) %></span>
          </span>
        </dd>
      </div>
      <% if root_article.source_role != "unknown" %>
        <div>
          <dt><%= t("investigations.root_article_panel.source_role") %></dt>
          <dd>
            <span class="has-popover">
              <%= root_article.source_role.humanize %>
              <span class="popover-content"><%= source_role_description(root_article.source_role) %></span>
            </span>
          </dd>
        </div>
      <% end %>
      <div>
        <dt><%= t("investigations.root_article_panel.linked_sources") %></dt>
        <dd><%= root_article.sourced_links.count %></dd>
      </div>
    </dl>

    <% if root_article.excerpt.present? %>
      <p class="excerpt"><%= root_article.excerpt %></p>
    <% end %>
  <% end %>
</article>
