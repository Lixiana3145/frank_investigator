<li id="<%= dom_id(step) %>">
  <span>
    <%= step.name.humanize %>
    <% if (duration = pipeline_step_duration(step)) %>
      <span class="muted"> &middot; <%= duration %></span>
    <% end %>
  </span>
  <span class="<%= badge_class_for(step.status) %>"><%= step.status.humanize %></span>
</li>
