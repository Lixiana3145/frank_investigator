<% content_for :title, t(".title") %>

<main class="w-full max-w-[1120px] mx-auto px-4 py-8 pb-16">
  <header class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-6">
    <div>
      <p class="mb-3 text-muted text-xs tracking-[0.14em] uppercase"><%= t(".eyebrow") %></p>
      <h1 class="font-serif text-[clamp(2.2rem,5vw,4rem)] leading-[0.95]"><%= t(".heading") %></h1>
    </div>
    <% if @error_reports.any? %>
      <%= button_to t(".clear_all"), destroy_all_error_reports_path, method: :delete, class: "min-h-12 px-5 py-3 border-0 rounded-full bg-ink text-white cursor-pointer font-serif", data: { turbo_confirm: t(".confirm_clear") } %>
    <% end %>
  </header>

  <% if @error_reports.empty? %>
    <section class="border border-line bg-card backdrop-blur-sm rounded-3xl p-5 shadow-lg">
      <p class="text-muted"><%= t(".empty") %></p>
    </section>
  <% else %>
    <section class="border border-line bg-card backdrop-blur-sm rounded-3xl p-5 shadow-lg col-span-full">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr>
              <th class="text-left px-3 py-2 border-b-2 border-line text-muted text-xs uppercase tracking-wide"><%= t(".severity") %></th>
              <th class="text-left px-3 py-2 border-b-2 border-line text-muted text-xs uppercase tracking-wide"><%= t(".error") %></th>
              <th class="text-left px-3 py-2 border-b-2 border-line text-muted text-xs uppercase tracking-wide"><%= t(".occurrences") %></th>
              <th class="text-left px-3 py-2 border-b-2 border-line text-muted text-xs uppercase tracking-wide"><%= t(".last_seen") %></th>
            </tr>
          </thead>
          <tbody>
            <% @error_reports.each do |report| %>
              <tr>
                <td class="px-3 py-2.5 border-b border-line/40 align-top"><span class="<%= report.severity == 'error' ? badge_class_for('failed') : badge_class_for('pending') %>"><%= report.severity %></span></td>
                <td class="px-3 py-2.5 border-b border-line/40 align-top"><%= link_to "#{report.error_class}: #{report.message.truncate(80)}", error_report_path(report), class: "text-ink" %></td>
                <td class="px-3 py-2.5 border-b border-line/40 align-top text-base font-bold"><%= report.occurrences_count %></td>
                <td class="px-3 py-2.5 border-b border-line/40 align-top text-muted"><%= time_ago_in_words(report.last_occurred_at) %> <%= t(".ago_suffix") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</main>
