<% content_for :title, t(".title") %>

<main class="page-shell">
  <header class="analysis-header">
    <div>
      <p class="eyebrow"><%= link_to t(".error_reports_link"), error_reports_path %></p>
      <h1><%= @error_report.error_class %></h1>
    </div>
  </header>

  <section class="content-grid">
    <article class="panel panel--wide">
      <dl class="fact-list">
        <div>
          <dt><%= t(".severity") %></dt>
          <dd><span class="badge <%= @error_report.severity == 'error' ? 'badge--red' : 'badge--amber' %>"><%= @error_report.severity %></span></dd>
        </div>
        <div>
          <dt><%= t(".message") %></dt>
          <dd><%= @error_report.message %></dd>
        </div>
        <div>
          <dt><%= t(".source") %></dt>
          <dd><%= @error_report.source.presence || t(".unknown_source") %></dd>
        </div>
        <div>
          <dt><%= t(".occurrences") %></dt>
          <dd class="metric-number"><%= @error_report.occurrences_count %></dd>
        </div>
        <div>
          <dt><%= t(".first_seen") %></dt>
          <dd><%= l(@error_report.first_occurred_at, format: :long) %></dd>
        </div>
        <div>
          <dt><%= t(".last_seen") %></dt>
          <dd><%= l(@error_report.last_occurred_at, format: :long) %></dd>
        </div>
      </dl>
    </article>

    <% if @error_report.backtrace.present? %>
      <article class="panel panel--wide">
        <h2><%= t(".backtrace") %></h2>
        <pre class="error-backtrace"><%= @error_report.backtrace %></pre>
      </article>
    <% end %>

    <% if @error_report.context.present? && @error_report.context != {} %>
      <article class="panel panel--wide">
        <h2><%= t(".context") %></h2>
        <pre class="error-backtrace"><%= JSON.pretty_generate(@error_report.context) %></pre>
      </article>
    <% end %>
  </section>
</main>
